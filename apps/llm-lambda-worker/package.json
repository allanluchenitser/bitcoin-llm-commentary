{
  "name": "@blc/llm-lambda-worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node ./dist/index.js",
    "dev": "npm run build && npm run start",
    "dev_bak": "nodemon --watch 'src/**/*.ts' --exec 'ts-node' src/index.ts",
    "test": "npm run build && node --experimental-vm-modules ../../node_modules/jest/bin/jest.js --config ./jest.config.cjs"
  },
  "description": "LLM Lambda Worker for subscribing to Redis events and sending to LLMs",
  "dependencies": {
    "@aws-sdk/client-lambda": "^3.992.0",
    "@blc/color-logger": "^0.0.0",
    "@blc/env": "^0.0.0",
    "@blc/redis-client": "0.0.0",
    "@blc/sse-client": "0.0.0",
    "date-fns": "^4.1.0",
    "openai": "^6.22.0",
    "tiktoken": "^1.0.22"
  },
  "devDependencies": {
    "@blc/contracts": "0.0.0",
    "@types/node": "^25.0.9",
    "jest": "^30.3.0",
    "typescript": "^5.9.3"
  }
}
